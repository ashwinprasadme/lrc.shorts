---
import { loadStories, getStoryIndex } from '../../lib/content';
import ReelFeed from '../../components/ReelFeed';
import '../../styles/global.css';

export async function getStaticPaths() {
  const stories = await loadStories();
  return stories.map((story) => ({
    params: { slug: story.slug },
  }));
}

const { slug } = Astro.params;
const stories = await loadStories();
const initialIndex = await getStoryIndex(slug);

// If story not found, start at 0
const startIndex = initialIndex >= 0 ? initialIndex : 0;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover" />
    <meta name="theme-color" content="#ffffff" />
    <meta name="description" content="Browse trending news from Left, Neutral, and Right perspectives - swipe to explore different viewpoints." />
    
    <title>LensReels - News from Every Angle</title>
    
    {/* PWA meta tags */}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    
    {/* Preconnect for performance */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    
    {/* Disable automatic text size adjustment on mobile */}
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  </head>
  <body>
    <ReelFeed client:only="react" stories={stories} initialSlide={startIndex} />
  </body>
</html>
